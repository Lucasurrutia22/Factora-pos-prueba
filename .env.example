# ============================================
# FACTORА-POS CONFIGURATION (.env)
# ============================================
# Copiar a .env y actualizar valores

# 🔐 SECURITY
SECRET_KEY=tu-clave-secreta-super-larga-aqui-cambiar-en-produccion
DEBUG=False
ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com,127.0.0.1

# ⚙️ ENVIRONMENT
ENVIRONMENT=production
DJANGO_SETTINGS_MODULE=FactoraPos.settings_production

# 🗄️ DATABASE - PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=factora_pos_db
DB_USER=factora_pos_user
DB_PASSWORD=tu-password-seguro-aqui
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# 🌐 DOMAIN & SECURITY
CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY=True

# 📧 EMAIL (opcional - para notificaciones)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-password-app-aqui

# 📊 LOGGING & MONITORING
SENTRY_DSN=
LOG_LEVEL=INFO

# 💾 STORAGE (archivos estáticos & media)
STATIC_ROOT=/var/www/factorа-pos/staticfiles
MEDIA_ROOT=/var/www/factora-pos/media
STATIC_URL=/static/
MEDIA_URL=/media/

# 🔌 REDIS (opcional - para caché)
REDIS_URL=redis://localhost:6379/0

# ⏰ TIMEZONE
TIME_ZONE=America/Santiago
